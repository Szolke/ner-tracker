# GitHub API Token - Get from: https://github.com/settings/tokens
GITHUB_TOKEN=your_token_here_ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Repository
GITHUB_REPO=Szolke/ner-tracker
GITHUB_OWNER=Szolke
GITHUB_REPO_NAME=ner-tracker
GITHUB_BRANCH=main

# Cloudflare Pages
CLOUDFLARE_PAGES_URL=https://ner-tracker.pages.dev
CLOUDFLARE_PROJECT_NAME=ner-tracker

# Scraper Settings
SCRAPER_RUN_TIME=08:00
SCRAPER_TIMEZONE=UTC

# News Data Path
NEWS_DATA_PATH=public/data/news.json

# Development
VITE_PORT=3000
VITE_HOST=localhost
